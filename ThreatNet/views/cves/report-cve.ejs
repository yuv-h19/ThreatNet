<%- include('../includes/head.ejs') %>
<link rel="stylesheet" href="/css/report-cve.css">
</head>
<body>
<%- include('../includes/menu.ejs') %>

<div class="cve-container">
  <section class="form-section">
    <div class="section-header">
      <h2>> REPORT_NEW_VULNERABILITY</h2>
      <p>Document technical details for the CVE database</p>
    </div>

    <div class="form-layout">
      <form action="/save-cve" method="POST" class="cve-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="cve_id">CVE ID <span>*</span></label>
            <input type="text" id="cve_id" name="cve_id" class="cyber-input" placeholder="CVE-2026-001" required>
          </div>
          <div class="form-group">
            <label for="cvss_score">CVSS Score (0-10) <span>*</span></label>
            <input type="number" id="cvss_score" name="cvss_score" step="0.1" min="0" max="10" class="cyber-input" placeholder="7.5" required>
          </div>

          <div class="form-group full-width">
            <label for="vulnerability_name">Vulnerability Name <span>*</span></label>
            <input type="text" id="vulnerability_name" name="vulnerability_name" class="cyber-input" placeholder="Remote Code Execution in..." required>
          </div>

          <div class="form-group">
            <label for="attack_vector">Attack Vector</label>
            <select id="attack_vector" name="attack_vector" class="cyber-input">
              <option value="Network">Network</option>
              <option value="Local">Local</option>
              <option value="Physical">Physical</option>
            </select>
          </div>
          <div class="form-group">
            <label for="attack_complexity">Attack Complexity</label>
            <select id="attack_complexity" name="attack_complexity" class="cyber-input">
              <option value="Low">Low</option>
              <option value="Medium">Medium</option>
              <option value="High">High</option>
            </select>
          </div>

          <div class="form-group full-width">
            <label for="affected_product">Affected Product <span>*</span></label>
            <input type="text" id="affected_product" name="affected_product" class="cyber-input" placeholder="e.g. Apache Server 2.4" required>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="cyber-btn">Submit CVE Report</button>
          <button type="reset" class="btn-reset">Reset</button>      
        </div>
      </form>

      <aside class="sidebar-section">
        <div class="info-card">
          <h3>CVSS Scoring Guide</h3>
          <ul class="score-list">
            <li><span class="badge critical">9.0 - 10.0</span> <span class="severity-label">Critical</span></li>
            <li><span class="badge high">7.0 - 8.9</span> <span class="severity-label">High</span></li>
            <li><span class="badge medium">4.0 - 6.9</span> <span class="severity-label">Medium</span></li>
            <li><span class="badge low">0.1 - 3.9</span> <span class="severity-label">Low</span></li>
          </ul>
        </div>

        <div class="info-card">
          <h3>Recent Submissions</h3>
          <div class="recent-list">
            <div class="recent-item">
              <span class="cve-id-link">CVE-2025-998</span>
              <p>Windows Kernel Elevation</p>
            </div>
            <div class="recent-item">
              <span class="cve-id-link">CVE-2025-102</span>
              <p>Chrome V8 Engine RCE</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</div>

<%- include('../includes/end.ejs') %>